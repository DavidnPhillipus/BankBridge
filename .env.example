# ---------------------------------------------------------------------------
# FinConnect environment variables (copy to .env and adjust as needed)
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
POSTGRES_USER=bankbridge
POSTGRES_PASSWORD=bankbridge
POSTGRES_DB=bankbridge
POSTGRES_PORT=5432
DATABASE_URL=postgresql://bankbridge:bankbridge@localhost:5432/bankbridge?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# --- Auth / JWT (replace secrets in real environments) ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=604800
BCRYPT_SALT_ROUNDS=12

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
